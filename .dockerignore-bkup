# =============================================================================
# Tool-Specific Exclusions
# =============================================================================
# Rust ecosystem
*.rs.bk                         # rustfmt backup files
.cargo-ok                       # Cargo build success marker
**/.rust-analyzer/              # Rust analyzer cache directories
rust-project.json               # Rust project configuration

# Node.js ecosystem
.pnp.*                          # Yarn Plug'n'Play
.yarn/                          # Yarn configuration and cache
lerna-debug.log*                # Lerna debug logs
.eslintcache                    # ESLint cache

# Python (if any Python tooling)

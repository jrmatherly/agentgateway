*.iso                           # ISO images
*.dmg                           # macOS disk images
*.pkg                           # Package files
*.deb                           # Debian packages
*.rpm                           # RPM packages
*.tar.gz                        # Compressed archives (unless needed)
*.zip                           # ZIP archives
*.rar                           # RAR archives

# Media files (usually not needed in runtime containers)
*.mp4                           # Video files
*.avi                           # Video files
*.mkv                           # Video files
*.mov                           # Video files
*.wmv                           # Video files

# Large image files (keep only essential ones)
*.psd                           # Photoshop files
*.ai                            # Adobe Illustrator files
*.sketch                        # Sketch files
*.fig                           # Figma files
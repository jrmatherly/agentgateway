# =============================================================================
# Docker Build Context Optimization for Agentgateway
# =============================================================================
# This file optimizes Docker build performance and security by excluding
# unnecessary files from the build context sent to the Docker daemon.

# =============================================================================
# Build Artifacts & Compilation Output  
# =============================================================================
# Exclude all build outputs - Docker will generate fresh builds
target/                          # Rust build artifacts
**/target/                       # Workspace target directories
**/debug/                        # Debug build outputs  
**/release/                      # Release build outputs
**/*.rlib                        # Rust library files
**/*.rmeta                       # Rust metadata files
**/*.d                           # Dependency files

# Node.js build artifacts
ui/node_modules/                 # npm dependencies (will be installed in container)
**/node_modules/                 # All Node.js dependencies
ui/.next/                        # Next.js build cache
ui/out/                          # Next.js static exports
ui/dist/                         # Distribution builds
**/build/                        # Generic build directories
**/coverage/                     # Test coverage reports

# =============================================================================
# Cache & Temporary Files
# =============================================================================
# Exclude all caches - containers should have clean build environment
.cargo/                          # Cargo registry cache
**/.cargo/                       # Local cargo caches
.rust-analyzer/                  # Rust analyzer cache
**/.cache/                       # Generic cache directories
**/.npm/                         # npm cache
**/.yarn/                        # Yarn cache
**/.pnpm-store/                  # pnpm cache

# Temporary files
*.tmp                            # Temporary files
*.temp                           # Temporary files  
*.cache                          # Cache files
*.log                            # Log files (generated fresh in container)
logs/                            # Log directories
temp/                            # Temporary directories
tmp/                             # Temporary directories

# =============================================================================
# Development Environment Files
# =============================================================================
# IDE and editor configurations
.idea/                           # IntelliJ IDEA
.vscode/                         # VS Code (but keep settings for container dev)
!.vscode/devcontainer.json       # Keep dev container config
!.vscode/settings.json           # Keep container-relevant settings
.devcontainer.json               # Dev container config
*.swp                            # Vim swap files
*.swo                            # Vim swap files
*~                               # Editor backup files

# Development tools
.editorconfig                    # Editor configuration (not needed in runtime)
.prettier*                       # Prettier configuration
.eslint*                         # ESLint configuration (used at build time only)

# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store                        # macOS directory metadata
.DS_Store?                       # macOS metadata variants
._*                              # macOS resource forks
Thumbs.db                        # Windows thumbnail cache
Thumbs.db:encryptable            # Windows encrypted thumbnails
Desktop.ini                      # Windows desktop settings
$RECYCLE.BIN/                    # Windows recycle bin

# =============================================================================
# Version Control & CI/CD
# =============================================================================
.git/                            # Git repository data
.gitignore                       # Git ignore rules
.gitattributes                   # Git attributes
.gitmodules                      # Git submodules

# GitHub and CI/CD
.github/                         # GitHub workflows and configurations
!.github/workflows/docker.yml    # Keep Docker-specific workflows if needed
.gitlab-ci.yml                   # GitLab CI configuration
.travis.yml                      # Travis CI configuration
.circleci/                       # CircleCI configuration
.jenkinsfile                     # Jenkins pipeline
azure-pipelines.yml              # Azure DevOps pipelines

# =============================================================================
# Documentation (Excluded from Runtime Containers)
# =============================================================================
# Keep only essential runtime documentation
docs/                           # Documentation directory
*.md                            # Markdown files
README*                         # README files
CHANGELOG*                      # Changelog files
CONTRIBUTING*                   # Contributing guidelines
CODE_OF_CONDUCT*                # Code of conduct
LICENSE*                        # License files (except production license)
!LICENSE                        # Keep main license for attribution
AUTHORS*                        # Author information
CREDITS*                        # Credits
MAINTAINERS*                    # Maintainer information

# Generated documentation
/doc/                           # Rust generated docs
**/book/                        # mdBook outputs
site/                           # Documentation site

# =============================================================================
# Configuration Files (Development Only)
# =============================================================================
# Build and development configuration files not needed in container runtime
deny.toml                       # Rust deny configuration
rustfmt.toml                    # Rust formatting configuration
.taplo.toml                     # TOML formatter configuration
rust-toolchain.toml             # Rust toolchain specification (handled by Dockerfile)
clippy.toml                     # Clippy linting configuration

# Package manager configurations
# .npmrc                          # npm configuration
# .yarnrc*                        # Yarn configuration  
# .pnpmrc                         # pnpm configuration
# package-lock.json               # npm lock file (generated in container)
# yarn.lock                       # Yarn lock file (generated in container)
# pnpm-lock.yaml                  # pnpm lock file (generated in container)

# =============================================================================
# Examples & Test Data (Excluded from Production)
# =============================================================================
examples/                       # Example configurations
test-data/                      # Test datasets
fixtures/                       # Test fixtures
benchmarks/                     # Benchmark code and data
**/tests/                       # Test directories (exclude from runtime)


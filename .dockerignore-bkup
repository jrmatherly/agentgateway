# =============================================================================
# Runtime Data Directories (Development)
# =============================================================================
# Data directories that shouldn't be in container images
data/                           # Application data
volumes/                        # Docker volume mounts
.data/                          # Hidden data directories

# Database files
*.db                            # SQLite databases
*.sqlite*                       # SQLite database files
redis-data/                     # Redis data

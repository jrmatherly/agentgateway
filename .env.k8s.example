# Kubernetes Environment Variables for Agentgateway
# This file contains Kubernetes-specific environment variables
# Typically these are auto-injected by Kubernetes/Istio but can be set manually

# ==================================================================
# KUBERNETES POD METADATA (Auto-Injected by Downward API)
# ==================================================================

# Pod Information
INSTANCE_IP=${POD_IP}                    # Pod IP address (from downward API)
POD_NAME=${POD_NAME}                     # Kubernetes pod name
POD_NAMESPACE=${POD_NAMESPACE}           # Kubernetes pod namespace  
NODE_NAME=${NODE_NAME}                   # Kubernetes node name

# Alternative naming conventions
K8S_NAMESPACE=${POD_NAMESPACE}           # Alternative namespace variable
K8S_POD_NAME=${POD_NAME}                 # Alternative pod name variable
K8S_NODE_NAME=${NODE_NAME}               # Alternative node name variable

# ==================================================================
# SERVICE MESH CONFIGURATION (Istio/Envoy)
# ==================================================================

# xDS Dynamic Configuration
XDS_ADDRESS=http://istiod.istio-system.svc.cluster.local:15010  # Istio control plane
NAMESPACE=${POD_NAMESPACE}               # Service mesh namespace
GATEWAY=agentgateway                     # Gateway instance name
NETWORK=                                 # Network name for multi-network mesh

# ==================================================================
# CERTIFICATE AUTHORITY & mTLS (Istio)
# ==================================================================

# CA Configuration for Istio mTLS
CA_ADDRESS=http://istiod.istio-system.svc.cluster.local:15012   # Istio CA server
TRUST_DOMAIN=cluster.local               # Service mesh trust domain
SERVICE_ACCOUNT=agentgateway             # Kubernetes service account
CLUSTER_ID=Kubernetes                    # Cluster identifier

# Service Account Token (auto-mounted by Kubernetes)
AUTH_TOKEN=/var/run/secrets/kubernetes.io/serviceaccount/token
CA_ROOT_CA=/var/run/secrets/istio/root-cert.pem  # Istio root CA certificate

# ==================================================================
# KUBERNETES RESOURCE LIMITS (Downward API)
# ==================================================================

# Resource information from Kubernetes downward API
CPU_LIMIT=${CPU_LIMIT}                   # From resources.limits.cpu
MEMORY_LIMIT=${MEMORY_LIMIT}             # From resources.limits.memory
CPU_REQUEST=${CPU_REQUEST}               # From resources.requests.cpu
MEMORY_REQUEST=${MEMORY_REQUEST}         # From resources.requests.memory

# ==================================================================
# KUBERNETES SERVICES & DISCOVERY
# ==================================================================

# Kubernetes DNS-based service discovery
POSTGRES_HOST=postgres.${POD_NAMESPACE}.svc.cluster.local
REDIS_HOST=redis.${POD_NAMESPACE}.svc.cluster.local
PROMETHEUS_HOST=prometheus.${POD_NAMESPACE}.svc.cluster.local

# OpenTelemetry Collector (typically in observability namespace)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
OTLP_PROTOCOL=grpc

# ==================================================================
# PRODUCTION KUBERNETES CONFIGURATION
# ==================================================================

# Production-specific settings for Kubernetes
WORKER_THREADS=${CPU_LIMIT:-100%}        # Use all available CPU cores
THREADING_MODE=thread_per_core           # Maximum performance mode
TERMINATION_GRACE_PERIOD_SECONDS=60      # Kubernetes termination grace period

# Enhanced observability for production
OTLP_HEADERS=service=agentgateway,environment=production,cluster=${CLUSTER_ID},namespace=${POD_NAMESPACE}

# ==================================================================
# MULTI-CLUSTER & FEDERATION (Advanced)
# ==================================================================

# Multi-cluster mesh configuration (uncomment if needed)
# EXTERNAL_ISTIOD=istiod-remote.istio-system.svc.cluster.local:15012
# CLUSTER_NETWORK=network1              # Cluster network identifier
# PILOT_EXTERNAL_GALLEY=false           # Use external Galley
# PILOT_ENABLE_WORKLOAD_ENTRY_AUTOREGISTRATION=true

# Federation settings (uncomment if needed)
# FEDERATION_ENDPOINT=                  # Cross-cluster federation endpoint
# CLUSTER_REGISTRY_SECRET=              # Multi-cluster service registry

# ==================================================================
# SECURITY CONTEXT & RBAC
# ==================================================================

# Security context (typically auto-configured)
SECURITY_CONTEXT_RUN_AS_USER=65532       # Non-root user ID
SECURITY_CONTEXT_RUN_AS_GROUP=65532      # Non-root group ID  
SECURITY_CONTEXT_FS_GROUP=65532          # File system group

# RBAC and service account
RBAC_ENABLED=true                        # Enable Kubernetes RBAC
SERVICE_ACCOUNT_NAME=agentgateway        # Service account for RBAC

# ==================================================================
# MONITORING & HEALTH CHECKS
# ==================================================================

# Kubernetes health check endpoints
READINESS_ADDR=0.0.0.0:15021            # Readiness probe endpoint
STATS_ADDR=0.0.0.0:15020                # Stats/metrics endpoint for Kubernetes

# Prometheus annotations (for auto-discovery)
PROMETHEUS_SCRAPE=true                   # Enable Prometheus scraping
PROMETHEUS_PATH=/metrics                 # Metrics path
PROMETHEUS_PORT=8080                     # Metrics port

# ==================================================================
# VOLUME MOUNTS & SECRETS
# ==================================================================

# Common Kubernetes volume mount paths
CONFIG_VOLUME_PATH=/etc/agentgateway     # ConfigMap mount path
SECRET_VOLUME_PATH=/etc/secrets          # Secret mount path
TLS_CERT_PATH=/etc/tls                   # TLS certificate mount path

# Istio-specific volume mounts
ISTIO_CA_ROOT=/var/run/secrets/istio     # Istio CA root certificate
ISTIO_TOKEN=/var/run/secrets/tokens/istio-token  # Istio service account token
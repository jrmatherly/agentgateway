# Environment Variables Configuration for Agentgateway
# Copy this file to .env and customize for your environment

# ==================================================================
# DOCKER BUILD OPTIMIZATION
# ==================================================================

# Disable Docker BuildKit provenance attestations for faster development builds
# This resolves the "resolving provenance for metadata file" delay that can
# cause builds to hang for 7+ minutes. Safe for development/local builds.
BUILDX_NO_DEFAULT_ATTESTATIONS=1

# ==================================================================
# CORE APPLICATION SETTINGS
# ==================================================================

# Logging Configuration
RUST_LOG=info                   # Log level: error, warn, info, debug, trace
RUST_BACKTRACE=0                # Enable backtrace on panic (0=off, 1=on)

# Network Configuration
IPV6_ENABLED=true              # Enable IPv6 support
ADMIN_ADDR=0.0.0.0:15000       # Admin interface binding
STATS_ADDR=0.0.0.0:15020       # Metrics endpoint binding  
READINESS_ADDR=0.0.0.0:15021   # Health check endpoint binding

# ==================================================================
# PERFORMANCE & THREADING
# ==================================================================

# Worker Thread Configuration
WORKER_THREADS=75%              # Number of threads: fixed number (4) or percentage (75%)
CPU_LIMIT=                      # Override detected CPU count (useful in containers)
THREADING_MODE=default          # Threading model: default | thread_per_core

# ==================================================================
# HTTP/2 PROTOCOL OPTIMIZATION  
# ==================================================================

# Stream and Connection Windows
HTTP2_STREAM_WINDOW_SIZE=4194304      # Per-stream window (4MB default)
HTTP2_CONNECTION_WINDOW_SIZE=16777216 # Per-connection window (16MB default)
HTTP2_FRAME_SIZE=1048576              # HTTP/2 frame size (1MB default)

# Connection Pooling
POOL_MAX_STREAMS_PER_CONNECTION=100   # Max streams per HTTP/2 connection
POOL_UNUSED_RELEASE_TIMEOUT=300s      # Release unused connections after timeout

# ==================================================================
# CONNECTION MANAGEMENT
# ==================================================================

# Graceful Shutdown Configuration
CONNECTION_MIN_TERMINATION_DEADLINE=5s    # Minimum time for graceful shutdown
CONNECTION_TERMINATION_DEADLINE=30s       # Maximum time before force close
TERMINATION_GRACE_PERIOD_SECONDS=30       # Kubernetes termination grace period

# Network Identification
NETWORK=                        # Network name for service mesh

# ==================================================================
# xDS DYNAMIC CONFIGURATION
# ==================================================================

# xDS Server Configuration (for dynamic config updates)
XDS_ADDRESS=                    # xDS server URL (e.g., http://istiod:15010)
LOCAL_XDS_PATH=                 # Local config file path (alternative to xDS)
NAMESPACE=                      # Service mesh namespace
GATEWAY=                        # Gateway instance name

# ==================================================================
# CERTIFICATE AUTHORITY & SECURITY
# ==================================================================

# CA Configuration
CA_ADDRESS=                     # Certificate Authority server URL
TRUST_DOMAIN=cluster.local      # Service mesh trust domain
SERVICE_ACCOUNT=                # Kubernetes service account
CLUSTER_ID=Kubernetes           # Cluster identifier
AUTH_TOKEN=                     # Authentication token path or value
CA_ROOT_CA=/var/run/secrets/istio/root-cert.pem  # Root CA certificate

# ==================================================================
# OBSERVABILITY & TELEMETRY
# ==================================================================

# OpenTelemetry Configuration
OTLP_ENDPOINT=                 # OpenTelemetry collector endpoint
OTLP_PROTOCOL=grpc             # Protocol: grpc | http/protobuf
OTLP_HEADERS=                  # Custom headers: JSON {"key":"value"} or csv key1=val1,key2=val2

# Metrics
PROMETHEUS_ENDPOINT=0.0.0.0:8080  # Prometheus metrics endpoint

# ==================================================================
# KUBERNETES DEPLOYMENT
# ==================================================================
# For Kubernetes-specific environment variables, see: .env.k8s.example
# That file contains all Kubernetes/Istio-specific configuration including:
# - Pod metadata (POD_NAME, POD_IP, etc.)
# - Service mesh configuration (xDS, mTLS, CA)
# - Multi-cluster settings
# - Resource limits and health checks

# ==================================================================
# DATABASE & CACHE CREDENTIALS (Docker Compose)
# ==================================================================

# Redis Configuration
REDIS_PASSWORD=secure_redis_password_change_me

# PostgreSQL Configuration  
POSTGRES_DB=agentgateway
POSTGRES_USER=agentgateway
POSTGRES_PASSWORD=secure_postgres_password_change_me

# ==================================================================
# DEVELOPMENT & DEBUGGING
# ==================================================================

# Development Overrides (uncomment for development)
# RUST_LOG=debug
# RUST_BACKTRACE=1
# WORKER_THREADS=4
# OTLP_HEADERS={"service":"agentgateway-dev","environment":"development"}

# ==================================================================
# PRODUCTION OPTIMIZATIONS
# ==================================================================

# Production Settings (uncomment for production)
# RUST_LOG=warn
# WORKER_THREADS=100%
# THREADING_MODE=thread_per_core
# HTTP2_STREAM_WINDOW_SIZE=16777216
# HTTP2_CONNECTION_WINDOW_SIZE=67108864
# POOL_MAX_STREAMS_PER_CONNECTION=500
# CONNECTION_TERMINATION_DEADLINE=60s

# ==================================================================
# GRAFANA CONFIGURATION (Docker Compose)
# ==================================================================

# Grafana Admin Credentials
GF_SECURITY_ADMIN_PASSWORD=secure_grafana_admin_password_change_me
GF_USERS_ALLOW_SIGN_UP=false

# ==================================================================
# CONTAINER BUILD CONFIGURATION
# ==================================================================

# Docker Build Arguments
BUILDER=base                     # Build type: base | musl
PROFILE=release                  # Build profile: release | debug | dev  
TARGETARCH=                      # Target architecture (auto-detected)
VERSION=dev                      # Application version
BUILD_DATE=                      # Build timestamp (auto-generated)
VCS_REF=                         # Git commit hash (auto-generated)